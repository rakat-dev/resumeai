# ─── Required ───────────────────────────────────────────────────────────────

# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# RapidAPI key for JSearch (real job listings)
# 1. Go to https://rapidapi.com/letscrape-6bRB4TkqmJD/api/jsearch
# 2. Sign up free (200 requests/month free)
# 3. Copy your API key from the dashboard
RAPIDAPI_KEY=your_rapidapi_key_here

# Adzuna API — free job search (sign up at https://developer.adzuna.com)
ADZUNA_APP_ID=your_adzuna_app_id
ADZUNA_APP_KEY=your_adzuna_app_key
